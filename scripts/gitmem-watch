#!/usr/bin/env bash
#
# gitmem-watch - Automatic file change detection and GitMem commit
#
# This script monitors the project directory for file changes and automatically
# commits them to .gitmem, ensuring no agent edit is ever lost.
#
# Usage:
#   gitmem-watch [options]
#
# Options:
#   --debounce SECONDS    Time to wait before committing (default: 2)
#   --exclude PATTERN     Additional exclude pattern (can be repeated)
#   --include PATTERN     Force include pattern (overrides excludes)
#   --dry-run             Show what would be committed without committing
#   --verbose             Show detailed output
#
# Requirements:
#   Linux: inotify-tools (apt-get install inotify-tools)
#   macOS: fswatch (brew install fswatch)
#

set -e

# Default options
DEBOUNCE_SECONDS=2
EXTRA_EXCLUDES=()
INCLUDES=()
DRY_RUN=false
VERBOSE=false

GITMEM_DIR=".gitmem"
GITMEM_GIT="${GITMEM_DIR}/.git"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[gitmem]${NC} $*"
}

log_warn() {
    echo -e "${YELLOW}[gitmem]${NC} $*"
}

log_error() {
    echo -e "${RED}[gitmem]${NC} $*" >&2
}

log_debug() {
    if $VERBOSE; then
        echo -e "${CYAN}[gitmem]${NC} $*"
    fi
}

gitmem_cmd() {
    git --git-dir="${GITMEM_GIT}" --work-tree=. "$@"
}

check_dependencies() {
    if [[ "$(uname)" == "Darwin" ]]; then
        if ! command -v fswatch &> /dev/null; then
            log_error "fswatch not found. Install with: brew install fswatch"
            exit 1
        fi
        WATCHER="fswatch"
    else
        if ! command -v inotifywait &> /dev/null; then
            log_error "inotifywait not found. Install with: apt-get install inotify-tools"
            exit 1
        fi
        WATCHER="inotify"
    fi
}

check_gitmem() {
    if [[ ! -d "${GITMEM_GIT}" ]]; then
        log_error "GitMem not initialized. Run 'gitmem init' first."
        exit 1
    fi
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --debounce)
            DEBOUNCE_SECONDS="$2"
            shift 2
            ;;
        --exclude)
            EXTRA_EXCLUDES+=("$2")
            shift 2
            ;;
        --include)
            INCLUDES+=("$2")
            shift 2
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --verbose|-v)
            VERBOSE=true
            shift
            ;;
        --help|-h)
            head -30 "$0" | tail -28
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Default exclude patterns
DEFAULT_EXCLUDES=(
    "\.git"
    "\.gitmem"
    "__pycache__"
    "node_modules"
    "\.pyc$"
    "\.swp$"
    "~$"
    "\.tmp$"
    "\.log$"
    "\.DS_Store"
    "Thumbs\.db"
)

# Build exclude regex
EXCLUDE_PATTERN=$(IFS='|'; echo "${DEFAULT_EXCLUDES[*]}${EXTRA_EXCLUDES:+|}${EXTRA_EXCLUDES[*]}")

should_track() {
    local file="$1"

    # Check if matches exclude pattern
    if echo "$file" | grep -qE "$EXCLUDE_PATTERN"; then
        # Check if it matches any include pattern
        for pattern in "${INCLUDES[@]}"; do
            if echo "$file" | grep -qE "$pattern"; then
                return 0
            fi
        done
        return 1
    fi
    return 0
}

commit_file() {
    local file="$1"

    if [[ ! -f "$file" ]]; then
        log_debug "Skipping non-file: $file"
        return
    fi

    if ! should_track "$file"; then
        log_debug "Excluded: $file"
        return
    fi

    if $DRY_RUN; then
        log_info "[DRY-RUN] Would commit: $file"
        return
    fi

    log_info "Auto-committing: $file"

    gitmem_cmd add -- "$file" 2>/dev/null
    gitmem_cmd commit -m "agent(edit): ${file}

reason: auto-detected file change (watch mode)" 2>/dev/null

    if [[ $? -eq 0 ]]; then
        log_info "✓ Committed to GitMem"
    else
        log_debug "No changes to commit for: $file"
    fi
}

# Debounce mechanism
PENDING_FILES=()
LAST_COMMIT=0

flush_pending() {
    if [[ ${#PENDING_FILES[@]} -eq 0 ]]; then
        return
    fi

    log_info "Flushing ${#PENDING_FILES[@]} pending file(s)..."

    for file in "${PENDING_FILES[@]}"; do
        commit_file "$file"
    done

    PENDING_FILES=()
    LAST_COMMIT=$(date +%s)
}

add_pending() {
    local file="$1"

    # Check if already pending
    for pending in "${PENDING_FILES[@]}"; do
        if [[ "$pending" == "$file" ]]; then
            return
        fi
    done

    PENDING_FILES+=("$file")

    # Check if we should flush
    local now=$(date +%s)
    local elapsed=$((now - LAST_COMMIT))

    if [[ $elapsed -ge $DEBOUNCE_SECONDS ]]; then
        flush_pending
    fi
}

watch_inotify() {
    log_info "Using inotify (Linux)"
    log_info "Monitoring for file changes... (Ctrl+C to stop)"
    echo ""

    # Also monitor moved_to events (for temp file renames) and delete events
    inotifywait -m -r -e modify,create,close_write,moved_to \
        --exclude "$EXCLUDE_PATTERN" \
        . 2>/dev/null | while read -r dir event file; do

        local full_path="${dir}${file}"
        log_debug "Event: $event on $full_path"

        # Handle temp file patterns - if file matches .tmp.* pattern,
        # extract the base filename and commit that instead
        if echo "$file" | grep -qE '\.tmp\.[0-9]+\.[0-9]+$'; then
            # This is a temp file, extract the base name
            local base_file=$(echo "$file" | sed -E 's/\.tmp\.[0-9]+\.[0-9]+$//')
            full_path="${dir}${base_file}"
            log_debug "Detected temp file, will commit base file: $full_path"
        fi

        # Only commit if the file exists (not deleted)
        if [[ -f "$full_path" ]]; then
            add_pending "$full_path"
        fi
    done
}

watch_fswatch() {
    log_info "Using fswatch (macOS)"
    log_info "Monitoring for file changes... (Ctrl+C to stop)"
    echo ""

    fswatch -r --exclude "$EXCLUDE_PATTERN" \
        --event Changed --event Created --event Renamed \
        . 2>/dev/null | while read -r file; do

        log_debug "Changed: $file"

        # Handle temp file patterns - if file matches .tmp.* pattern,
        # extract the base filename and commit that instead
        if echo "$file" | grep -qE '\.tmp\.[0-9]+\.[0-9]+$'; then
            local base_file=$(echo "$file" | sed -E 's/\.tmp\.[0-9]+\.[0-9]+$//')
            file="$base_file"
            log_debug "Detected temp file, will commit base file: $file"
        fi

        # Only commit if the file exists
        if [[ -f "$file" ]]; then
            add_pending "$file"
        fi
    done
}

# Cleanup on exit
cleanup() {
    echo ""
    log_info "Stopping file watcher..."
    flush_pending
    log_info "Done."
}

trap cleanup EXIT

# Main
check_dependencies
check_gitmem

log_info "GitMem Watch Mode"
log_info "Debounce: ${DEBOUNCE_SECONDS}s"
log_info "Exclude patterns: ${EXCLUDE_PATTERN}"
if [[ ${#INCLUDES[@]} -gt 0 ]]; then
    log_info "Force includes: ${INCLUDES[*]}"
fi
echo ""

case "$WATCHER" in
    inotify)
        watch_inotify
        ;;
    fswatch)
        watch_fswatch
        ;;
esac